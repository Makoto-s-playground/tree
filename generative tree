<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Recursive Sakura with Falling Petals</title>
    <style>
        body { margin: 0; background: #0f172a; overflow: hidden; font-family: sans-serif; }
        #controls { position: absolute; top: 20px; left: 20px; color: white; background: rgba(0,0,0,0.5); padding: 15px; border-radius: 8px; z-index: 10; }
        canvas { display: block; }
    </style>
</head>
<body>
    <div id="controls">
        <label>Wind Intensity</label><br>
        <input type="range" id="windSlider" min="0" max="10" step="0.1" value="2">
    </div>
    <canvas id="treeCanvas"></canvas>

<script>
    const canvas = document.getElementById('treeCanvas');
    const ctx = canvas.getContext('2d');
    const windSlider = document.getElementById('windSlider');
    
    let width, height, time = 0, growth = 0;
    const petals = [];

    class Petal {
        constructor(x, y) {
            this.x = x;
            this.y = y;
            this.size = Math.random() * 4 + 2;
            this.vX = (Math.random() - 0.5) * 2;
            this.vY = Math.random() * 1 + 0.5;
            this.angle = Math.random() * 360;
            this.opacity = 1;
        }
        update(wind) {
            this.x += this.vX + (wind * 0.5);
            this.y += this.vY;
            this.angle += 2;
            if (this.y > height - 10) {
                this.y = height - 10;
                this.opacity -= 0.005; // Fade out on ground
            }
        }
        draw() {
            ctx.save();
            ctx.globalAlpha = this.opacity;
            ctx.translate(this.x, this.y);
            ctx.rotate(this.angle * Math.PI / 180);
            ctx.fillStyle = "#fda4af";
            ctx.beginPath();
            ctx.ellipse(0, 0, this.size, this.size/2, 0, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
        }
    }

    function resize() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    function drawTree(x, y, len, angle, depth) {
        if (depth > growth) return;

        ctx.save();
        ctx.beginPath();
        ctx.translate(x, y);
        ctx.rotate(angle * Math.PI / 180);
        
        ctx.strokeStyle = `hsl(25, 40%, ${20 + depth * 5}%)`;
        ctx.lineWidth = 12 * Math.pow(0.7, depth);
        
        ctx.moveTo(0, 0);
        ctx.lineTo(0, -len);
        ctx.stroke();

        const currentWind = parseFloat(windSlider.value) * Math.sin(time + depth * 0.5);

        if (depth >= 9) {
            // Draw Blossom
            ctx.fillStyle = "#fda4af";
            ctx.beginPath();
            ctx.arc(0, -len, 4, 0, Math.PI * 2);
            ctx.fill();

            // Random chance to spawn a falling petal if fully grown
            if (growth >= 10 && Math.random() < 0.002 * windSlider.value) {
                // Transform local canvas coords to global screen coords
                const matrix = ctx.getTransform();
                petals.push(new Petal(matrix.e, matrix.f - len));
            }
        }

        if (depth < 10) {
            drawTree(0, -len, len * 0.78, -20 + currentWind, depth + 1);
            drawTree(0, -len, len * 0.78, 25 + currentWind, depth + 1);
        }
        ctx.restore();
    }

    function animate() {
        ctx.clearRect(0, 0, width, height);
        time += 0.02;
        if (growth < 10) growth += 0.03;

        // Draw and update petals
        for (let i = petals.length - 1; i >= 0; i--) {
            petals[i].update(parseFloat(windSlider.value));
            petals[i].draw();
            if (petals[i].opacity <= 0) petals.splice(i, 1);
        }

        drawTree(width / 2, height - 50, height / 5, 0, 0);
        requestAnimationFrame(animate);
    }

    animate();
</script>
</body>
</html>
